{
  "name": "react-opcua-client-exe",
  "version": "2.6.6",
  "description": "Professional Industrial Protocol Client (OPC UA & EtherNet/IP)",
  "main": "electron/main.js",
  "author": "Yan Weiping (Xiao Liu Zi)",
  "homepage": "./",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.xiaoliuzi.industrialclient",
    "productName": "Industrial Client Suite",
    "copyright": "Copyright © 2024 Yan Weiping",
    "directories": {
      "output": "dist_electron",
      "buildResources": "assets"
    },
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/dll",
        "to": "dll",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/dlls",
        "to": "dll",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dll",
        "to": "dll",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "@xenova/transformers": "^2.14.0",
    "chokidar": "^3.6.0",
    "docx": "^9.6.1",
    "ethernet-ip": "^1.2.5",
    "file-saver": "^2.0.5",
    "iconv-lite": "^0.6.3",
    "jsmodbus": "^4.0.6",
    "koffi": "^2.9.0",
    "lucide-react": "^0.358.0",
    "modbus-serial": "^8.0.25",
    "node-opcua": "^2.133.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-virtualized-auto-sizer": "^1.0.24",
    "react-window": "^1.8.10",
    "recharts": "^3.8.1",
    "serialport": "^13.0.0",
    "sonner": "^2.0.7"
  },
  "overrides": {
    "chokidar": "^3.6.0",
    "hexy": "0.3.4"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.0",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
